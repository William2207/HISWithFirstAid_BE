#!/bin/bash
# Pre-commit hook for FirstAid API
# Place this file in .git/hooks/pre-commit
# Make it executable: chmod +x .git/hooks/pre-commit

set -e

echo "Running pre-commit checks..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if dotnet is installed
if ! command -v dotnet &> /dev/null; then
    echo -e "${RED}? .NET CLI not found${NC}"
    exit 1
fi

echo -e "${YELLOW}?? Checking staged C# files...${NC}"

# Get staged C# files
STAGED_CS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cs$' || true)

if [ -z "$STAGED_CS_FILES" ]; then
    echo -e "${GREEN}? No C# files to check${NC}"
    exit 0
fi

echo "Found C# files to check:"
echo "$STAGED_CS_FILES" | sed 's/^/   - /'

# Build check
echo -e "${YELLOW}?? Building project...${NC}"
if ! dotnet build --configuration Debug --no-restore > /tmp/build.log 2>&1; then
    echo -e "${RED}? Build failed${NC}"
    cat /tmp/build.log
    exit 1
fi
echo -e "${GREEN}? Build successful${NC}"

# Code format check
echo -e "${YELLOW}?? Checking code format...${NC}"
if ! dotnet format --verify-no-changes --verbosity diagnostic > /tmp/format.log 2>&1; then
    echo -e "${YELLOW}??  Code formatting issues found${NC}"
    echo "Run: dotnet format"
    # Continue (not exiting) to allow manual review
fi

echo -e "${GREEN}? Pre-commit checks passed${NC}"
echo "Proceeding with commit..."

exit 0
