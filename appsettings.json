  },
  "Frontend": {
    "Url": "http://localhost:5173",
    "StoreUrl": "http://localhost:5173",
    "HISUrl": "http://localhost:5175",
    "AdminUrl": "http://localhost:5174"
  },
  "RagSettings": {
    "BaseUrl": "http://localhost:9621"
  },
  "Gemini": {
    "ApiKey": "your_api_key"
  }
